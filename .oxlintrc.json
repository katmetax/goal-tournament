{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "typescript", "unicorn", "oxc", "vue", "vitest"],
  "env": {
    "browser": true
  },
  "categories": {
    "correctness": "error"
  },
  "overrides": [
    {
      "files": ["env.d.ts"],
      "rules": {
        "typescript/triple-slash-reference": "off"
      }
    }
  ]
}
